# ===== Aetheria RPG — Environment =====
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (npm start จะโหลด .env ให้อัตโนมัติ)

# --- Database ---
# กำหนด DATABASE_URL เพื่อใช้ PostgreSQL (แนะนำ). ถ้าเว้นว่างจะ fallback เป็น SQLite
# บน Railway: เพิ่ม PostgreSQL plugin แล้วค่านี้จะถูกตั้งให้อัตโนมัติ
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ตั้ง true เมื่อต่อ Postgres ภายนอกที่บังคับ SSL (public URL ของ Railway/Neon/Supabase ฯลฯ)
# ใช้ Postgres ภายใน network ของ Railway ให้ปล่อยเป็น false
DATABASE_SSL=false

# --- Security ---
# คีย์ลับสำหรับเซ็น JWT — ตั้งเป็นค่าสุ่มยาว ๆ ของคุณเอง
JWT_SECRET=change-me-to-a-long-random-string

# --- Server ---
# พอร์ต (Railway ตั้งให้อัตโนมัติ ตอน deploy ไม่ต้องกำหนด)
PORT=3000
